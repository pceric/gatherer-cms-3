{% extends 'base.html.twig' %}

{% block title %}{% trans %}Home{% endtrans %}{% endblock %}

{% block body %}
    {# Empty state — no sticky posts and no feed items yet #}
    {% if sticky is empty and feed is empty %}
        <div class="text-center py-5">
            <i class="bi bi-basket3 fs-1 text-muted"></i>
            <h2 class="mt-3">{% trans with {'%name%': config.get('name') | default(engine_name)} %}Welcome to %name%{% endtrans %}</h2>
            <p class="text-muted">{% trans %}There's nothing here yet. Head over to the administration area to create your first post or configure an RSS feed to ingest.{% endtrans %}</p>
            <a href="{{ path('admin') }}" class="btn btn-primary mt-2">{% trans %}Get started{% endtrans %}</a>
        </div>
    {% endif %}
    {# Print out our sticky posts first if we have any #}
    {% if sticky %}
        {% for sloop in sticky %}
            <article class="sticky mb-5">
                <header>
                    <h3 class="title">{{ sloop.title|u.truncate(96, '...') }}</h3>
                    <p class="article-authorship text-muted small">
                        <small>
                            <i class="bi-pin-fill" title="sticky"></i> <time datetime="{{ sloop.pubdate|date('c') }}">{{ sloop.pubdate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time> by {{ sloop.author }}<br />
                            {% if sloop.moddate %}(Modified <time datetime="{{ sloop.moddate|date('c') }}">{{ sloop.moddate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time>){% endif %}
                        </small>
                    </p>
                </header>
                <div class="article-body" id="i{{ sloop.id }}">
                    {{ sloop.content|paragraph|raw }}
                </div>
                <div class="article-meta mt-1">
                    <hr class="my-0">
                    <div class="d-flex justify-content-between align-items-center">
                    <div>{{ sloop.tags|tagify }}</div>
                    <div class="d-flex align-items-center gap-2 text-muted">
                        {% if is_granted('ROLE_EDITOR') %}
                            <a href="{{ path('admin_blog_edit', {slug: sloop.slug}) }}" title="{% trans %}Edit{% endtrans %}" aria-label="{% trans %}Edit{% endtrans %}"><i class="bi bi-pencil-square"></i></a>
                        {% endif %}
                        <a href="{{ url('blog_show', { slug: sloop.slug }) }}" title="{% trans %}Permalink{% endtrans %}" aria-label="{% trans %}Permalink{% endtrans %}"><i class="bi bi-link-45deg"></i></a>
                    </div>
                    </div>
                </div>
            </article>
        {% endfor %}
    {% endif %}
    {# Now our top 8 regular posts #}
    {% for floop in feed|slice(0, 8) %}
        <article class="{{ floop.entity }} mb-5">
            <header>
                <h3 class="title">{{ floop.title|u.truncate(96, '...') }}</h3>
                <p class="article-authorship text-muted small">
                    <small>
                        <time datetime="{{ floop.pubdate|date('c') }}">{{ floop.pubdate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time>{% if floop.source is defined %} from {{ parse_url(floop.source).host }}{% else %} by {{ floop.author }}{% endif %}<br />
                        {% if floop.moddate is defined and floop.moddate is not empty %}(Modified <time datetime="{{ floop.moddate|date('c') }}">{{ floop.moddate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time>){% endif %}
                    </small>
                </p>
            </header>
            <div class="article-body">
                {% if floop.entity == 'reader' %}
                    <blockquote class="blockquote ms-4">
                        {{ floop.content|paragraph|raw }}
                        <p>
                            <a href="{{ floop.source }}" target="_blank">{% trans %}Read More{% endtrans %} <i class="bi bi-box-arrow-up-right" style="font-size: 0.9em;"></i></a>
                        </p>
                    </blockquote>
                    {% if is_granted('ROLE_EDITOR') %}
                        {{ include('blog/_annotation_editor.html.twig', {annotation: floop.annotation, url: path('admin_reader_annotation', {id: floop.id})}) }}
                    {% elseif floop.annotation is not empty %}
                        <p class="shadow-none p-3 bg-body-secondary rounded annotation">{{ floop.annotation|raw }}</p>
                    {% endif %}
                {% else %}
                    {{ floop.content|summarize|raw }}
                    <p><a href="{{ url('blog_show', {slug: floop.slug}) }}">{% trans %}Read Full Article{% endtrans %} <i class="bi bi-arrow-right" style="font-size: 0.9em;"></i></a></p>
                {% endif %}
            </div>
            <div class="article-meta mt-1">
                <hr>
                <div class="d-flex justify-content-between align-items-center">
                <div>{{ floop.tags|tagify }}</div>
                <div class="d-flex align-items-center gap-2 text-muted">
                    {% if is_granted('ROLE_EDITOR') and floop.entity != 'reader' %}
                        <a href="{{ path('admin_blog_edit', {slug: floop.slug}) }}" title="{% trans %}Edit{% endtrans %}" aria-label="{% trans %}Edit{% endtrans %}"><i class="bi bi-pencil-square"></i></a>
                    {% endif %}
                    <a href="{{ url(floop.entity == 'reader' ? 'reader_show' : 'blog_show', { slug: floop.slug }) }}" title="{% trans %}Permalink{% endtrans %}" aria-label="{% trans %}Permalink{% endtrans %}"><i class="bi bi-link-45deg"></i></a>
                </div>
                </div>
            </div>
        </article>
    {% endfor %}
    {% if sticky is not empty or feed is not empty %}
    <section id="archives-link-row" class="text-center my-4">
        <a href="{{ path('blog_archives') }}" class="btn btn-outline-secondary">
            <i class="bi bi-archive me-2"></i>{% trans %}View Archives{% endtrans %}
        </a>
    </section>
    {% endif %}
{% endblock %}
