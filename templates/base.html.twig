{% set frankenphp_hot_reload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
<!DOCTYPE html>
<html lang="{{ app.request.getLocale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content="{{ engine_name }} v{{ engine_major_version }}">
    <meta name="author" content="{{ config.get('author') }}">
    <meta name="description" content="{{ config.get('desc') }}">
    <meta name="keywords" content="{{ config.get('keywords') }}">
    {% if frankenphp_hot_reload %}<meta name="frankenphp-hot-reload:url" content="{{ frankenphp_hot_reload }}">{% endif %}
    <title>{% block title %}Unknown{% endblock %} - {{ config.get('name') | default(engine_name) }}</title>
    <link rel="alternate" type="application/atom+xml" title="Atom Feed" href="{{ path('feed', {type: 'atom'}) }}">
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="{{ path('feed', {type: 'rss'}) }}">
    <script>(function(){var t=localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');document.documentElement.setAttribute('data-bs-theme',t)})();</script>
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% block stylesheets %}{% endblock %}
</head>
<body data-controller="theme local-time">
<nav class="navbar fixed-top navbar-expand-lg bg-body-tertiary">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('home_page') }}">{{ config.get('name') | default(engine_name) }}</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link{% if app.request.getPathInfo() == "/" %} active{% endif %}" href="{{ path('home_page') }}">{% trans %}Home{% endtrans %}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link{% if app.request.getPathInfo() in ["/blog", "/blog/archives"] %} active{% endif %}" href="{{ path('blog_archives') }}">{% trans %}News{% endtrans %}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link{% if app.request.getPathInfo() starts with "/blog/article" %} active{% endif %}" href="{{ path('article') }}">{% trans %}Articles{% endtrans %}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link{% if app.request.getPathInfo() == "/contact" %} active{% endif %}" href="{{ path('contact') }}">{% trans %}Contact{% endtrans %}</a>
                </li>
                {% if app.user %}
                    <li class="nav-item dropdown ms-4">
                        <a class="nav-link{% if app.request.getPathInfo() == "/admin" %} active{% endif %} dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            {{ app.user.displayname ?: app.user.userIdentifier }}
                        </a>
                        <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <a class="dropdown-item" href="{{ path('admin') }}">{% trans %}Administration{% endtrans %}</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="{{ path('app_logout') }}">{% trans %}Logout{% endtrans %}</a>
                        </div>
                    </li>
                {% endif %}
            </ul>
            {% if available.elasticsearch %}
            <form class="d-flex" method="get" action="{{ path('search') }}" role="search">
                <input class="form-control form-control-sm me-2" type="search" name="q" value="{{ app.request.query.get('q', '')|e }}" placeholder="Search…" aria-label="Search">
                <button class="btn btn-outline-secondary btn-sm" type="submit"><i class="bi-search"></i></button>
            </form>
            {% endif %}
        </div>
    </div>
</nav>
<div class="container min-vh-100">
    <div class="row">
        <div class="col-lg-9" id="body-content">
            {% block body %}{% endblock %}
        </div>
        <div class="col-lg-3 d-print-none mt-4 mt-lg-0" id="sidebar-content">
            <aside>
                {% block sidebar %}
                    <section id="follow-us">
                        <h5 class="list-title">{% trans %}Follow Us{% endtrans %}</h5>
                        <ul class="list-group list-group-flush pb-3">
                            <li class="list-group-item">
                                <a href="{{ path('feed') }}" title="RSS"><i class="bi-rss-fill text-body"></i></a>
                                {% for social in social_names() %}
                                    {% set uri = attribute(config, 'get', [social ~ '_uri', 'follow', '']) %}
                                    {% if uri %}<a href="{{ uri }}" title="{{ social }}"><i class="bi-{{ social }} text-body"></i></a>{% endif %}
                                {% endfor %}
                            </li>
                        </ul>
                    </section>
                    <section id="latest-news">
                        <h5 class="list-title">{% trans %}Latest News{% endtrans %}</h5>
                        {{ render(controller(
                            'App\\Controller\\BlogController::recentBlogs', {limit: 8}
                        )) }}
                    </section>
                    <section id="latest-articles">
                        <h5 class="list-title">{% trans %}Latest Articles{% endtrans %}</h5>
                        {{ render(controller(
                            'App\\Controller\\BlogController::recentArticles', {limit: 8}
                        )) }}
                    </section>
                {% endblock %}
            </aside>
        </div>
    </div>
</div>
<footer class="mt-3 py-3">
    <div class="container" id="footer-content">
        {% block footer %}
            <section id="footer-nav">
                <ul class="nav justify-content-center border-bottom pb-3 mb-3">
                    <li class="nav-item"><a class="nav-link px-3 text-muted" href="{{ path('home_page') }}">{% trans %}Home{% endtrans%}</a></li>
                    <li class="nav-item"><a class="nav-link px-3 text-muted" href="{{ path('blog_archives') }}">{% trans %}News{% endtrans%}</a></li>
                    <li class="nav-item"><a class="nav-link px-3 text-muted" href="{{ path('article') }}">{% trans %}Articles{% endtrans%}</a></li>
                    <li class="nav-item"><a class="nav-link px-3 text-muted" href="{{ path('contact') }}">{% trans %}Contact{% endtrans%}</a></li>
                </ul>
            </section>
            <section id="footer-copyright"><p class="text-center text-muted">{% trans %}Copyright{% endtrans%} &copy; {{ "now"|date("Y") }} {{ config.get('author') }}</p></section>
            <section id="footer-theme" class="text-center">
                <button class="btn btn-link text-muted p-0" data-action="theme#toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                    <i class="bi bi-moon-fill" data-theme-target="icon"></i>
                </button>
            </section>
        {% endblock %}
    </div>
</footer>
{% block javascripts %}{% endblock %}
{% if frankenphp_hot_reload %}
<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
{% endif %}
</body>
</html>
