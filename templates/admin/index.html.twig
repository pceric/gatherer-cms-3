{% extends 'base.html.twig' %}

{% block title %}{% trans %}Administration{% endtrans %}{% endblock %}

{% block stylesheets %}
<style>
.admin-card {
    transition: transform .15s ease, box-shadow .15s ease;
    cursor: pointer;
}
.admin-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.12) !important;
}
.admin-card .card-icon {
    width: 3rem;
    height: 3rem;
    border-radius: .75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
}
</style>
{% endblock %}

{% block body %}
    {{ include('_flashes.html.twig') }}

    <div class="d-flex align-items-center mb-4 pt-2">
        <div>
            <h1 class="h3 mb-0">{% trans %}Administration{% endtrans %}</h1>
            <p class="text-muted mb-0 small">{% trans with {'%name%': app.user.displayname ?: app.user.userIdentifier} %}Welcome back, %name%{% endtrans %}</p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 g-3">

        {% if is_granted('ROLE_ADMIN') %}
        <div class="col">
            <div class="card border-0 shadow-sm h-100 admin-card">
                <div class="card-body d-flex gap-3 align-items-start p-4">
                    <div class="card-icon bg-primary bg-opacity-10 text-primary flex-shrink-0">
                        <i class="bi bi-sliders"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            <a href="{{ path('admin_settings') }}" class="stretched-link text-body text-decoration-none">{% trans %}Site Settings{% endtrans %}</a>
                        </h5>
                        <p class="card-text text-muted small mb-0">{% trans %}Configure site name, author, social links, and feed sources.{% endtrans %}</p>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="col">
            <div class="card border-0 shadow-sm h-100 admin-card">
                <div class="card-body d-flex gap-3 align-items-start p-4">
                    <div class="card-icon bg-success bg-opacity-10 text-success flex-shrink-0">
                        <i class="bi bi-journal-text"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            <a href="{{ path('admin_blog') }}" class="stretched-link text-body text-decoration-none">{% trans %}Blog Entries{% endtrans %}</a>
                        </h5>
                        <p class="card-text text-muted small mb-0">{% trans %}Create, edit, and delete native blog posts.{% endtrans %}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card border-0 shadow-sm h-100 admin-card">
                <div class="card-body d-flex gap-3 align-items-start p-4">
                    <div class="card-icon bg-warning bg-opacity-10 text-warning flex-shrink-0">
                        <i class="bi bi-rss"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            <a href="{{ path('admin_gathered') }}" class="stretched-link text-body text-decoration-none">{% trans %}Gathered Feed Entries{% endtrans %}</a>
                        </h5>
                        <p class="card-text text-muted small mb-0">{% trans %}Review and annotate content ingested from external RSS/Atom feeds.{% endtrans %}</p>
                    </div>
                </div>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="col">
            <div class="card border-0 shadow-sm h-100 admin-card">
                <div class="card-body d-flex gap-3 align-items-start p-4">
                    <div class="card-icon bg-info bg-opacity-10 text-info flex-shrink-0">
                        <i class="bi bi-tags"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            <a href="{{ path('admin_category') }}" class="stretched-link text-body text-decoration-none">{% trans %}Categories{% endtrans %}</a>
                        </h5>
                        <p class="card-text text-muted small mb-0">{% trans %}Add and remove blog post categories.{% endtrans %}</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm h-100 admin-card">
                <div class="card-body d-flex gap-3 align-items-start p-4">
                    <div class="card-icon bg-secondary bg-opacity-10 text-secondary flex-shrink-0">
                        <i class="bi bi-people"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            <a href="{{ path('admin_users') }}" class="stretched-link text-body text-decoration-none">{% trans %}Users{% endtrans %}</a>
                        </h5>
                        <p class="card-text text-muted small mb-0">{% trans %}Add, edit, and remove user accounts and roles.{% endtrans %}</p>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

    </div>
{% endblock %}

{% block sidebar %}{% endblock %}
