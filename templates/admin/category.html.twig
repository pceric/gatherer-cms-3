{% extends 'base.html.twig' %}

{% block title %}{% trans %}Categories{% endtrans %}{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin') }}">{% trans %}Administration{% endtrans %}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{% trans %}Categories{% endtrans %}</li>
        </ol>
    </nav>
    <h2 class="mb-4"><i class="bi bi-tags me-2 text-info"></i>{% trans %}Categories{% endtrans %}</h2>
    {{ include('_flashes.html.twig') }}

    <form method="post" action="{{ path('admin_category_create') }}" class="d-flex gap-2 mb-3">
        <input type="text" name="name" class="form-control" placeholder="{{ 'New category name'|trans }}" maxlength="32" required>
        <button type="submit" class="btn btn-primary text-nowrap"><i class="bi bi-plus-lg me-1"></i>{% trans %}Add Category{% endtrans %}</button>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th scope="col">{% trans %}Action{% endtrans %}</th>
                <th scope="col">{% trans %}Name{% endtrans %}</th>
                <th scope="col">{% trans %}Slug{% endtrans %}</th>
                <th scope="col">{% trans %}Posts{% endtrans %}</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
            <tr>
                <td>
                    {% if category.name != 'General' %}
                        <a href="#"
                           data-href="{{ path('admin_category_delete', {'id': category.id}) }}"
                           data-bs-toggle="modal"
                           data-bs-target="#confirm-delete">
                            <i class="bi bi-trash" title="{% trans %}Delete{% endtrans %}" data-bs-toggle="tooltip"></i>
                        </a>
                    {% else %}
                        <i class="bi bi-lock text-muted" title="{% trans %}Protected{% endtrans %}" data-bs-toggle="tooltip"></i>
                    {% endif %}
                </td>
                <td>{{ category.name }}</td>
                <td><code>{{ category.slug }}</code></td>
                <td>{{ category.blogs|length }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="modal fade" id="confirm-delete" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="staticBackdropLabel">{% trans %}Really Delete?{% endtrans %}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{% trans %}Delete this category? This action is not reversible.{% endtrans %}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{% trans %}Close{% endtrans %}</button>
                    <button type="button" class="btn btn-primary">{% trans %}Delete{% endtrans %}</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script type="module">
    import * as bootstrap from 'bootstrap';
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
    const modal = document.getElementById('confirm-delete');
    modal.addEventListener('show.bs.modal', function(e) {
        const deleteUrl = e.relatedTarget.closest('[data-href]').dataset.href;
        modal.querySelector('.btn-primary').addEventListener('click', () => location.assign(deleteUrl), { once: true });
    });
</script>
{% endblock %}

{% block sidebar %}{% endblock %}
