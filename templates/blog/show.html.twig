{% extends 'base.html.twig' %}

{% block title %}{{ blog.title }}{% endblock %}

{% block body %}
    <article class="blog">
        <header>
            <h3 class="blog-title">{{ blog.title }}</h3>
            <p class="blog-authorship text-muted small">
                <small>
                    <time datetime="{{ blog.pubdate|date('c') }}">{{ blog.pubdate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time>{% if blog.source is defined %} from {{ parse_url(blog.source).host }}{% else %} by {{ blog.author }}{% endif %}<br />
                    {% if blog.moddate %}(Modified <time datetime="{{ blog.moddate|date('c') }}">{{ blog.moddate|format_datetime(pattern: 'MMM dd, y hh:mm a z') }}</time>){% endif %}
                </small>
            </p>
        </header>
        <div class="blog-body" id="blog-app">
            {% if blog.source is defined %}
            <blockquote class="blockquote ms-4">
            {{ content|paragraph|raw }}
            </blockquote>
            {% else %}
            {{ content|paragraph|raw }}
            {% endif %}
            {% if blog.source is defined %}
                <p><a href="{{ blog.source }}" target="_blank">{% trans %}Read More{% endtrans %}  <i class="bi bi-box-arrow-up-right" style="font-size: 0.9em;"></i></a></p>
            {% endif %}
        </div>
        {% if blog.source is defined %}
            {% if is_granted('ROLE_EDITOR') %}
                {{ include('blog/_annotation_editor.html.twig', {annotation: blog.annotation, url: path('admin_reader_annotation', {id: blog.id})}) }}
            {% elseif blog.annotation is not empty %}
                <p class="shadow-none p-3 bg-body-secondary rounded annotation">{{ blog.annotation }}</p>
            {% endif %}
        {% endif %}
        {% if pager.haveToPaginate() %}
        <hr class="gradient">
        <nav aria-label="page" class="mt-3 pagination-sm justify-content-center">
            {{ pagerfanta(pager, {'omitFirstPage': true, 'template': 'bs5_blog_pager.html.twig' }) }}
        </nav>
        {% endif %}
        <div class="blog-meta mt-1">
            <hr class="gradient">
            <div class="d-flex justify-content-between align-items-center">
                <div>{{ blog.tags|tagify }}</div>
                <div class="d-flex align-items-center gap-2 text-muted">
                    {% if is_granted('ROLE_EDITOR') %}
                        <a href="{{ path('admin_blog_edit', {slug: blog.slug}) }}" title="{% trans %}Edit{% endtrans %}" aria-label="{% trans %}Edit{% endtrans %}"><i class="bi bi-pencil-square"></i></a>
                    {% endif %}
                </div>
            </div>
        </div>
    </article>
    {% if config.get('enabled', 'disqus') and config.get('domain', 'disqus') is not empty %}
    <div id="disqus_thread"></div>
    <script>
        var disqus_config = function () {
        this.page.url = '{{ app.request.uri }}'
        this.page.identifier = '{{ blog.guid }}'
        };
        (function() { // DON'T EDIT BELOW THIS LINE
            var d = document, s = d.createElement('script');
            s.src = 'https://{{ config.get('domain', 'disqus') }}.disqus.com/embed.js';
            s.setAttribute('data-timestamp', +new Date());
            (d.head || d.body).appendChild(s);
        })();
    </script>
    <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if config.get('enabled', 'disqus') and config.get('domain', 'disqus') is not empty %}
    <script id="dsq-count-scr" src="//{{ config.get('domain', 'disqus') }}.disqus.com/count.js" async></script>
    {% endif %}
{% endblock %}
